ENVIRONMENT=development
POSTGRES_DB_URL=host=localhost port=5432 user=postgres password=postgres dbname=tokengate sslmode=disable
REDIS_URL=redis://localhost:6379
API_KEY_PEPPER=change-me-in-production

# Stripe (optional — billing endpoints return 503/empty without these)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...

# Stripe Sandbox (optional — super admin users use sandbox Stripe for test billing)
STRIPE_SANDBOX_SECRET_KEY=sk_test_...
STRIPE_SANDBOX_WEBHOOK_SECRET=whsec_...
STRIPE_SANDBOX_PRICE_PRO_MONTHLY=price_...
STRIPE_SANDBOX_PRICE_TEAM_MONTHLY=price_...
STRIPE_SANDBOX_PRICE_BUSINESS_MONTHLY=price_...

# Cloudflare R2 (optional — audit report artifacts fall back to DB blob without these)
R2_ENDPOINT=https://637b68e092d3265dab4b86a3b392f958.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_ACCESS_KEY_SECRET=
R2_BUCKET_NAME=tokengate-audit-reports

# SMTP (optional — email notifications return an error without these)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@example.com

# Better Stack logging (optional — logs only go to stdout without this)
BETTERSTACK_SOURCE_TOKEN=
